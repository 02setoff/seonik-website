generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  occupation        String?
  howFound          String?
  joinReason        String?
  newsletterConsent        Boolean   @default(false)
  newsletterConsentAt      DateTime?
  newsletterUnsubscribedAt DateTime?
  privacyConsentAt         DateTime?
  loginAttempts            Int       @default(0)
  loginLockedUntil         DateTime?
  mustResetPassword        Boolean   @default(false)
  theme                    String    @default("light")
  region                   String?
  affiliation              String?
  startupStage             String?
  onboarded                Boolean   @default(false)
  createdAt                DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  posts     Post[]
  likes     Like[]
  postViews PostView[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id               String   @id @default(cuid())
  code             String?  @unique  // 코드명: INTEL-001 형식
  title            String
  summary          String?           // 지휘관 요약 (3문장)
  source           String?           // 첩보 소스 (데이터 출처)
  bmBreakdown      String?           // BM 심층 해부
  playbook         String?           // 실행 가이드 (구독자 전용)
  actionItems      String?           // 체크리스트 (구독자 전용)
  content          String?           // 기존 HTML 본문 (하위 호환)
  deepDive         String?           // 05단계: 심층 분석 (구독자 전용)
  seonikNote       String?           // 06단계: 선익 코멘트 (구독자 전용)
  postType         String   @default("BRIEFING")  // BRIEFING | NOTICE | GENERAL
  category         String   @default("")           // 하위 호환용
  isFree           Boolean  @default(true)
  isSubscriberOnly Boolean  @default(false)
  published        Boolean  @default(false)
  viewCount        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  authorId         String?

  author    User?      @relation(fields: [authorId], references: [id])
  likes     Like[]
  postViews PostView[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostView {
  id       String   @id @default(cuid())
  userId   String
  postId   String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notice {
  id          String    @id @default(cuid())
  type        String
  title       String
  content     String
  important   Boolean   @default(false)
  published   Boolean   @default(true)
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Announcement {
  id           String    @id @default(cuid())
  title        String
  description  String?
  region       String    @default("전국")
  affiliation  String    @default("전체")
  stage        String    @default("전체")
  deadline     DateTime?
  applyUrl     String?
  organization String?
  source       String    @default("수동")
  sourceId     String?
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([published, deadline])
}
