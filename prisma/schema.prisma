generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Announcement {
  id           String    @id @default(cuid())
  title        String
  description  String?
  region       String    @default("전국")
  affiliation  String    @default("전체")
  stage        String    @default("전체")
  deadline     DateTime?
  applyUrl     String?
  organization String?
  source       String    @default("수동")
  sourceId     String?
  published    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([published, deadline])
}
